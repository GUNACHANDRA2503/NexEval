# Copy to .env (never commit .env). For local dev you can rely on config.json only.

# --- Secrets ---
# JWT_SECRET=your-strong-random-secret
# NEXEVAL_CREDENTIALS_KEY=

# --- Environment (development | production) ---
# NEXEVAL_ENV=development

# --- Managed Postgres (Neon, Supabase, Render, etc.) ---
# When set, host/port/name/user/password in config.json are ignored for the connection.
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# POSTGRES_URL=  # alias of DATABASE_URL

# --- Production CORS: comma-separated frontend origins (required for browser calls from a separate static host) ---
# CORS_ORIGINS=https://your-app.pages.dev,https://www.example.com

# OpenAI: not used for API calls server-wide. Each user adds their key in the app (Account).
